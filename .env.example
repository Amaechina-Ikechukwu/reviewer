DATABASE_URL=postgresql://reviewer:password@localhost:5432/reviewer
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Cloud Run sets PORT automatically (8080). Override locally if needed.
PORT=3000

# Local dev: ./uploads
# Cloud Run: /tmp/uploads (ephemeral — files lost on instance restart)
UPLOAD_DIR=./uploads

MAX_FILE_SIZE=52428800

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Email (nodemailer)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
